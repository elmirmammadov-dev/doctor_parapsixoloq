{
  "rewrites": [
    {
      "source": "/ru",
      "destination": "/api/render-lang?lang=ru"
    },
    {
      "source": "/en",
      "destination": "/api/render-lang?lang=en"
    },
    {
      "source": "/tr",
      "destination": "/api/render-lang?lang=tr"
    },
    {
      "source": "/blog/:id",
      "destination": "/api/render-blog?id=:id"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/:slug([a-z0-9][a-z0-9-]+[a-z0-9])",
      "destination": "/api/render-blog?slug=:slug"
    }
  ],
  "redirects": [
    {
      "source": "/blog-post.html",
      "has": [{ "type": "query", "key": "id", "value": "(?<id>.*)" }],
      "destination": "/blog/:id",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
