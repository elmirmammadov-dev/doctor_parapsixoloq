{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/render-index"
    },
    {
      "source": "/ru",
      "destination": "/api/render-lang?lang=ru"
    },
    {
      "source": "/en",
      "destination": "/api/render-lang?lang=en"
    },
    {
      "source": "/tr",
      "destination": "/api/render-lang?lang=tr"
    },
    {
      "source": "/blog/:id",
      "destination": "/api/redirect-blog?id=:id"
    },
    {
      "source": "/elanlar",
      "destination": "/api/render-announcements"
    },
    {
      "source": "/elanlar/:slug",
      "destination": "/api/render-announcement?slug=:slug"
    },
    {
      "source": "/kampaniyalar",
      "destination": "/api/render-campaigns"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/:slug([a-z0-9][a-z0-9-]+[a-z0-9])",
      "destination": "/api/render-blog?slug=:slug"
    }
  ],
  "redirects": [],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
